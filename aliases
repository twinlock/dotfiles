# /bin/zsh
# Convenient stuff
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

alias ag='ag --path-to-ignore ~/.agignore'
alias l="ls -Gal"
alias ls="ls -G"
alias ll="ls -Ghal"
alias empties="find . -empty -type d -maxdepth 2"
tableflip() {
  echo "（╯°□°）╯ ┻━┻";
}
alias pg="ps ax | grep -v grep | grep -i "
alias ip="ifconfig | grep 'inet '"
alias top='top -o cpu'

#git
alias gs='git status'

alias vim='nvim'
alias vimdiff='nvim'
#alias tmux="~/tess_bin/tmux_common.sh twinlock"

export VISUAL=nvim
export VISUAL=vim
export EDITOR="$VISUAL"
function restart-bluetooth(){
  sudo kextunload -b com.apple.iokit.BroadcomBluetoothHostControllerUSBTransport
  sudo kextload -b com.apple.iokit.BroadcomBluetoothHostControllerUSBTransport
}
alias restartbluetooth='restart-blutooth'

# actually make go work
unset GOFETCH_ALIASES
